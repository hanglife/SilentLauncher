{
  // NOTE: This example intentionally uses JSONC-style // comments.
  // SilentLauncher can read launcher.json with // comments and trailing commas.
  // Strict JSON validators may still report errors because standard JSON does not allow comments.
  // These comments are documentation only. You can delete them without changing how SilentLauncher runs.

  // Global startup delay, in seconds.
  // Allowed values: 0 or any positive integer.
  // What it does: waits for this many seconds after SilentLauncher starts, then starts the apps below.
  // Useful when Windows has just logged in and network, disks, USB services, tray apps, or antivirus
  // are not fully ready yet. Starting Kavita, Sideloadly, cloud drives, or sync tools too early can fail or hang.
  // Impact: a larger value starts every app later. Use 0 to skip the global wait.
  "startupDelaySeconds": 20,

  // Log file path.
  // Allowed values:
  // 1. Relative path, such as "SilentLauncher.log"; logs are written next to SilentLauncher.exe.
  // 2. Absolute path, such as "D:\\Launchers\\logs\\SilentLauncher.log".
  // 3. Empty string "" or remove this field to disable logging.
  // What it does: records whether each app started, its PID, whether it was skipped as already running,
  // and any startup errors.
  // Useful because scheduled tasks and hidden launches do not show a window when something fails.
  // The log helps identify wrong paths, wrong working directories, missing permissions, or app startup failures.
  // Impact: logging creates a text file. It can grow over time and may be deleted occasionally.
  "logFile": "SilentLauncher.log",

  // apps is the list of programs to launch.
  // You can add one or more apps. SilentLauncher processes them in array order.
  // Impact: earlier apps start first. If an app has delaySeconds, later apps wait until that delay finishes.
  "apps": [
    {
      // Name, used only in the log.
      // Allowed values: any Chinese or English text. You can also remove this field.
      // What it does: shows a friendly label in the log, such as [Kavita] started.
      // Impact: it does not affect startup behavior. If removed, the path is used in the log instead.
      "name": "Kavita",

      // Program path. Required.
      // Allowed values:
      // 1. Absolute path, such as "D:\\Apps\\Kavita\\Kavita.exe".
      // 2. Relative path, such as ".\\Kavita.exe", relative to the launcher.json directory.
      // 3. Environment variables, such as "%LOCALAPPDATA%\\Programs\\SomeApp\\app.exe".
      // What it does: tells SilentLauncher which exe to start.
      // Useful for avoiding shortcut working-directory problems or path-with-spaces issues in shell:startup.
      // Impact: a wrong path fails to start and writes an error to the log.
      "path": "D:\\Apps\\Kavita\\Kavita.exe",

      // Working directory.
      // Allowed values:
      // 1. Absolute path, such as "D:\\Apps\\Kavita".
      // 2. Relative path, such as ".".
      // 3. Remove this field or set it to null to automatically use the exe directory.
      // What it does: behaves like double-clicking the exe from this directory.
      // Useful because many portable apps and server apps load config, data, plugins, or runtime files
      // from the current directory. A wrong working directory may lose config or make the app exit immediately.
      // Impact: server apps and portable apps should usually set this explicitly.
      "workingDirectory": "D:\\Apps\\Kavita",

      // Startup arguments.
      // Allowed values: any command-line argument string. Use "" or remove this field when no arguments are needed.
      // What it does: passes arguments to the target exe, such as "--port 5000" or "--config D:\\config".
      // Useful when an app needs a port, config directory, or headless mode.
      // Impact: invalid arguments may make the app fail to start. Supported arguments depend on the target app.
      "arguments": "",

      // Per-app startup delay, in seconds.
      // Allowed values: 0 or any positive integer.
      // What it does: waits before starting this app.
      // Useful when another app must start first, or when USB/iTunes services should be ready before Sideloadly starts.
      // Impact: affects this app and every app after it in the list.
      "delaySeconds": 0,

      // Whether to hide the target app window.
      // Allowed values: true / false.
      // true: try to hide the main window after startup. Good for Kavita, Jellyfin, and background tools.
      // false: leave the window visible.
      // Useful for avoiding many windows opening in the foreground after login.
      // Impact: if a GUI app needs confirmation, login, or device selection, hiding it may hide where it is stuck.
      // For those apps, test with false first, then switch to true after it is stable.
      "hideWindow": true,

      // Whether to minimize the target app window.
      // Allowed values: true / false.
      // What it does: tries to minimize the app to the taskbar instead of fully hiding it.
      // Relationship with hideWindow: when hideWindow=true, hiding takes priority and minimizeWindow usually does not matter.
      // Useful when you want the app out of the way but still visible in the taskbar.
      // Impact: the app may still have a taskbar icon after being minimized.
      "minimizeWindow": false,

      // Whether to prevent duplicate launches.
      // Allowed values: true / false.
      // true: if the exe at the same path is already running, skip starting another copy.
      // false: every SilentLauncher run tries to start a new process.
      // Useful for avoiding duplicate server processes when a scheduled task runs more than once or the launcher is clicked repeatedly.
      // Impact: some apps intentionally support multiple instances. Use false only when you need that.
      "preventDuplicate": true,

      // Maximum time to wait for the target app main window, in milliseconds.
      // Allowed values: 0 or any positive integer.
      // What it does: some GUI apps create their window a few seconds after process startup.
      // SilentLauncher waits during this period and tries to hide or minimize the window.
      // Useful when a window appears too late and is not hidden at first.
      // Impact: a larger value keeps SilentLauncher running longer. It does not harm the target app.
      "waitForWindowMs": 8000,

      // Whether this app entry is enabled.
      // Allowed values: true / false.
      // true: process this app normally.
      // false: temporarily skip this app but keep its configuration.
      // Useful when troubleshooting startup issues without deleting the whole app block.
      // Impact: false means this app will not be started.
      "enabled": true,

      // Whether to start through Windows Shell.
      // Allowed values: true / false.
      // false: default. Starts directly with CreateProcess for better hide-window and duplicate-prevention control.
      // true: starts through ShellExecute, closer to double-clicking the file. Some apps that need file associations,
      // UAC, or special shell behavior may require this.
      // Useful when direct startup fails but manual double-click works.
      // Impact: true gives weaker CreateNoWindow control, so hiding may be less reliable than false.
      "useShellExecute": false
    },

    {
      "name": "Sideloadly",
      "path": "C:\\Program Files\\Sideloadly\\Sideloadly.exe",
      "workingDirectory": "C:\\Program Files\\Sideloadly",
      "arguments": "",
      "delaySeconds": 10,
      "hideWindow": true,
      "minimizeWindow": false,
      "preventDuplicate": true,
      "waitForWindowMs": 12000,
      "enabled": true,
      "useShellExecute": false
    }
  ]
}
